{
  "name": "eopix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "MOCK_MODE=true node scripts/dev-banner.js && next dev --turbo",
    "dev:live": "concurrently -n next,inngest -c cyan,magenta \"node scripts/dev-banner.js && next dev --turbo\" \"npx inngest-cli@latest dev -u http://localhost:3000/api/inngest\"",
    "inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx tsx scripts/tests/test-with-branch.ts",
    "test:e2e:mock": "MOCK_MODE=true playwright test --config e2e/playwright.config.ts",
    "docs": "cd docs && mint dev --port 3333",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@neondatabase/serverless": "^1.0.2",
    "@portabletext/react": "^6.0.3",
    "@prisma/adapter-neon": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@sanity/image-url": "^2.0.3",
    "@sentry/nextjs": "^10.38.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "embla-carousel-react": "^8.6.0",
    "inngest": "^3.51.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.33.0",
    "next": "^14.2.35",
    "next-sanity": "^9.12.3",
    "next-themes": "^0.4.6",
    "openai": "^6.18.0",
    "prisma": "^7.3.0",
    "react": "^18",
    "react-day-picker": "^9.13.1",
    "react-dom": "^18",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.6.2",
    "resend": "^6.9.4",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
