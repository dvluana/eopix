generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  createdAt DateTime   @default(now())
  purchases Purchase[]

  @@index([email])
}

model SearchResult {
  id        String     @id @default(cuid())
  term      String
  type      String
  name      String?
  data      Json
  summary   String?
  expiresAt DateTime
  createdAt DateTime   @default(now())
  purchases Purchase[]

  @@index([term, type, createdAt])
}

model Purchase {
  id                    String        @id @default(cuid())
  userId                String
  code                  String        @unique
  term                  String
  amount                Int
  status                String        @default("PENDING")
  stripePaymentIntentId String?       @unique
  buyerName             String?
  buyerCpfCnpj          String?
  termsAcceptedAt       DateTime
  paidAt                DateTime?
  searchResultId        String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  processingStep        Int           @default(0)
  refundAttempts        Int           @default(0)
  failureReason         String?
  failureDetails        String?
  refundReason          String?
  refundDetails         String?
  searchResult          SearchResult? @relation(fields: [searchResultId], references: [id])
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([term])
  @@index([status])
}

model Blocklist {
  id             String   @id @default(cuid())
  term           String   @unique
  associatedName String?
  reason         String
  createdAt      DateTime @default(now())
}

model LeadCapture {
  id        String   @id @default(cuid())
  email     String
  term      String?
  reason    String
  createdAt DateTime @default(now())
}

model MagicCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model RateLimit {
  id          String   @id @default(cuid())
  identifier  String
  action      String
  count       Int      @default(1)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([identifier, action])
  @@index([identifier, action, windowStart])
}

model WebhookLog {
  id        String   @id @default(cuid())
  eventKey  String   @unique
  event     String
  paymentId String
  processed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model LgpdRequest {
  id        String   @id @default(cuid())
  protocol  String   @unique
  nome      String
  cpfCnpj   String
  email     String
  tipo      String
  descricao String
  createdAt DateTime @default(now())

  @@index([protocol])
  @@index([cpfCnpj])
}

model ApiRequestLog {
  id           String   @id @default(cuid())
  purchaseId   String?
  purchaseCode String?
  term         String
  type         String
  source       String
  endpoint     String
  statusCode   Int?
  requestBody  Json?
  responseRaw  Json
  responseTime Int?
  error        String?
  createdAt    DateTime @default(now())

  @@index([purchaseCode])
  @@index([term, type])
  @@index([source])
  @@index([createdAt])
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
